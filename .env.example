# ============ RPC ============
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_KEY

# ============ Contract Addresses ============
# 8004 registry addresses are in packages/core/src/constants/addresses.ts
SIGIL_MIDDLEWARE_ADDRESS=0x_TO_BE_DEPLOYED

# ============ Supabase ============
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ============ Pinata (IPFS) ============
PINATA_JWT=YOUR_JWT

# ============ HyperSync ============
HYPERSYNC_BEARER_TOKEN=YOUR_TOKEN

# ============ AI (Agent SDK) ============
# Leave unset for OAuth (free dev). Set for deployed prod.
ANTHROPIC_API_KEY=

# ============ OpenRouter (optional, cheaper alternative) ============
# Set these to route Agent SDK through OpenRouter instead of Anthropic direct.
# MiniMax M2.7: $0.30/M input, $1.20/M output (vs Sonnet $3/$15).
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# ANTHROPIC_AUTH_TOKEN=<your-openrouter-key>
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=minimax/minimax-m2.7
# ANTHROPIC_SMALL_FAST_MODEL=minimax/minimax-m2.7

# ============ Auth ============
# API key for CRE -> backend communication
SIGIL_API_KEY=YOUR_RANDOM_SECRET

# ============ Deployer ============
# Retrieve from macOS Keychain:
# security find-generic-password -s "sigil.deployer" -a "private-key" -w
DEPLOYER_PRIVATE_KEY=
