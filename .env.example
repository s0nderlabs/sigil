# ============ RPC ============
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_KEY

# ============ Contract Addresses ============
# 8004 registry addresses are in packages/core/src/constants/addresses.ts
SIGIL_MIDDLEWARE_ADDRESS=0x_TO_BE_DEPLOYED

# ============ Supabase ============
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# ============ Pinata (IPFS) ============
PINATA_JWT=YOUR_JWT

# ============ HyperSync ============
HYPERSYNC_BEARER_TOKEN=YOUR_TOKEN

# ============ AI (Agent SDK) ============
# Leave unset for OAuth (free dev). Set for deployed prod.
ANTHROPIC_API_KEY=

# ============ Auth ============
# API key for CRE -> backend communication
SIGIL_API_KEY=YOUR_RANDOM_SECRET

# ============ Deployer ============
# Retrieve from macOS Keychain:
# security find-generic-password -s "sigil.deployer" -a "private-key" -w
DEPLOYER_PRIVATE_KEY=
